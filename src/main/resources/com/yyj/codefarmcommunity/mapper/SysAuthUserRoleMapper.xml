<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yyj.codefarmcommunity.mapper.SysAuthUserRoleMapper">

    <resultMap id="BaseResultMap" type="com.yyj.codefarmcommunity.entity.SysAuthUserRole">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="userId" column="user_id" jdbcType="BIGINT"/>
            <result property="roleId" column="role_id" jdbcType="BIGINT"/>
            <result property="createdBy" column="created_by" jdbcType="VARCHAR"/>
            <result property="createdTime" column="created_time" jdbcType="TIMESTAMP"/>
            <result property="updateBy" column="update_by" jdbcType="VARCHAR"/>
            <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
            <result property="isDeleted" column="is_deleted" jdbcType="INTEGER"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,user_id,role_id,created_by,created_time,update_by,
        update_time,is_deleted
    </sql>

    <insert id="insert" parameterType="com.yyj.codefarmcommunity.entity.SysAuthUserRole">
        INSERT INTO sys_auth_user_role (user_id, role_id, is_deleted, created_time, update_time)
        VALUES (#{userId}, #{roleId}, #{isDeleted}, NOW(), NOW())
    </insert>

    <update id="updateById" parameterType="com.yyj.codefarmcommunity.entity.SysAuthUserRole">
        UPDATE sys_auth_user_role
        SET user_id = #{userId},
            role_id = #{roleId},
            is_deleted = #{isDeleted},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM sys_auth_user_role
        WHERE id = #{id} AND is_deleted = 0
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM sys_auth_user_role
        WHERE user_id = #{userId} AND is_deleted = 0
    </select>

    <select id="selectByRoleId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM sys_auth_user_role
        WHERE role_id = #{roleId} AND is_deleted = 0
    </select>

    <select id="selectByUserIdAndRoleId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM sys_auth_user_role
        WHERE user_id = #{userId} AND role_id = #{roleId} AND is_deleted = 0
    </select>

    <delete id="deleteByUserId">
        DELETE FROM sys_auth_user_role
        WHERE user_id = #{userId}
    </delete>

    <delete id="deleteByUserIdAndRoleIds">
        DELETE FROM sys_auth_user_role
        WHERE user_id = #{userId} AND role_id IN
        <foreach collection="roleIds" item="roleId" open="(" close=")" separator=",">
            #{roleId}
        </foreach>
    </delete>
</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yyj.codefarmcommunity.mapper.SysAuthUserMapper">

    <resultMap id="BaseResultMap" type="com.yyj.codefarmcommunity.entity.SysAuthUser">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="userName" column="user_name" jdbcType="VARCHAR"/>
            <result property="nickName" column="nick_name" jdbcType="VARCHAR"/>
            <result property="email" column="email" jdbcType="VARCHAR"/>
            <result property="phone" column="phone" jdbcType="VARCHAR"/>
            <result property="password" column="password" jdbcType="VARCHAR"/>
            <result property="sex" column="sex" jdbcType="TINYINT"/>
            <result property="avatar" column="avatar" jdbcType="VARCHAR"/>
            <result property="status" column="status" jdbcType="TINYINT"/>
            <result property="introduce" column="introduce" jdbcType="VARCHAR"/>
            <result property="extJson" column="ext_json" jdbcType="VARCHAR"/>
            <result property="createdBy" column="created_by" jdbcType="VARCHAR"/>
            <result property="createdTime" column="created_time" jdbcType="TIMESTAMP"/>
            <result property="updateBy" column="update_by" jdbcType="VARCHAR"/>
            <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
            <result property="isDeleted" column="is_deleted" jdbcType="INTEGER"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,user_name,nick_name,email,phone,password,
        sex,avatar,status,introduce,ext_json,
        created_by,created_time,update_by,update_time,is_deleted
    </sql>

    <insert id="insert" parameterType="com.yyj.codefarmcommunity.entity.SysAuthUser">
        INSERT INTO sys_auth_user (user_name, password, nick_name, email, phone, status, is_deleted, created_time, update_time)
        VALUES (#{userName}, #{password}, #{nickName}, #{email}, #{phone}, #{status}, #{isDeleted}, NOW(), NOW())
    </insert>

    <update id="updateById" parameterType="com.yyj.codefarmcommunity.entity.SysAuthUser">
        UPDATE sys_auth_user
        SET user_name = #{userName},
            password = #{password},
            nick_name = #{nickName},
            email = #{email},
            phone = #{phone},
            status = #{status},
            is_deleted = #{isDeleted},
            update_by = #{updateBy},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM sys_auth_user
        WHERE id = #{id} AND is_deleted = 0
    </select>

    <select id="selectByUserName" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM sys_auth_user
        WHERE user_name = #{userName} AND is_deleted = 0
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM sys_auth_user
        WHERE is_deleted = 0
        ORDER BY id DESC
    </select>

    <select id="selectByCondition" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM sys_auth_user
        WHERE is_deleted = 0
        <if test="userName != null and userName != ''">
            AND user_name LIKE CONCAT('%', #{userName}, '%')
        </if>
        <if test="status != null">
            AND status = #{status}
        </if>
        ORDER BY id DESC
    </select>

    <select id="selectPage" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM sys_auth_user
        WHERE is_deleted = 0
        ORDER BY id DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="searchPage" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM sys_auth_user
        WHERE is_deleted = 0
        <if test="userName != null and userName != ''">
            AND user_name LIKE CONCAT('%', #{userName}, '%')
        </if>
        <if test="status != null">
            AND status = #{status}
        </if>
        ORDER BY id DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*)
        FROM sys_auth_user
        WHERE is_deleted = 0
    </select>

    <select id="countByCondition" resultType="long">
        SELECT COUNT(*)
        FROM sys_auth_user
        WHERE is_deleted = 0
        <if test="userName != null and userName != ''">
            AND user_name LIKE CONCAT('%', #{userName}, '%')
        </if>
        <if test="status != null">
            AND status = #{status}
        </if>
    </select>
</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yyj.codefarmcommunity.mapper.SysAuthRolePermissionMapper">

    <resultMap id="BaseResultMap" type="com.yyj.codefarmcommunity.entity.SysAuthRolePermission">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="roleId" column="role_id" jdbcType="BIGINT"/>
            <result property="permissionId" column="permission_id" jdbcType="BIGINT"/>
            <result property="createdBy" column="created_by" jdbcType="VARCHAR"/>
            <result property="createdTime" column="created_time" jdbcType="TIMESTAMP"/>
            <result property="updateBy" column="update_by" jdbcType="VARCHAR"/>
            <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
            <result property="isDeleted" column="is_deleted" jdbcType="INTEGER"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,role_id,permission_id,created_by,created_time,update_by,
        update_time,is_deleted
    </sql>

    <insert id="insert" parameterType="com.yyj.codefarmcommunity.entity.SysAuthRolePermission">
        INSERT INTO sys_auth_role_permission (role_id, permission_id, is_deleted, created_time, update_time)
        VALUES (#{roleId}, #{permissionId}, #{isDeleted}, NOW(), NOW())
    </insert>

    <update id="updateById" parameterType="com.yyj.codefarmcommunity.entity.SysAuthRolePermission">
        UPDATE sys_auth_role_permission
        SET role_id = #{roleId},
            permission_id = #{permissionId},
            is_deleted = #{isDeleted},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM sys_auth_role_permission
        WHERE id = #{id} AND is_deleted = 0
    </select>

    <select id="selectByRoleId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM sys_auth_role_permission
        WHERE role_id = #{roleId} AND is_deleted = 0
    </select>

    <select id="selectByPermissionId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM sys_auth_role_permission
        WHERE permission_id = #{permissionId} AND is_deleted = 0
    </select>

    <select id="selectByRoleIdAndPermissionId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM sys_auth_role_permission
        WHERE role_id = #{roleId} AND permission_id = #{permissionId} AND is_deleted = 0
    </select>

    <delete id="deleteByRoleId">
        DELETE FROM sys_auth_role_permission
        WHERE role_id = #{roleId}
    </delete>

    <delete id="deleteByRoleIdAndPermissionIds">
        DELETE FROM sys_auth_role_permission
        WHERE role_id = #{roleId} AND permission_id IN
        <foreach collection="permissionIds" item="permissionId" open="(" close=")" separator=",">
            #{permissionId}
        </foreach>
    </delete>

    <delete id="deleteByPermissionId">
        DELETE FROM sys_auth_role_permission
        WHERE permission_id = #{permissionId}
    </delete>
</mapper>
